# ============================================================
# Supabase — salin file ini menjadi .env.local lalu isi nilainya.
# .env.local JANGAN di-commit (sudah diabaikan oleh .gitignore).
# ============================================================

# URL & ANON KEY bersifat PUBLIK (boleh dipakai di klien).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SERVICE ROLE KEY bersifat RAHASIA — HANYA dipakai di sisi server.
# JANGAN beri prefix NEXT_PUBLIC_ dan JANGAN dipakai di komponen klien.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
